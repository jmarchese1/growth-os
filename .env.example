# ─── Embedo Environment Variables ────────────────────────────────────────────
# Copy to .env.local and fill in your values.
# Never commit .env.local to version control.

# ─── Core ────────────────────────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=info

# ─── Database (Supabase PostgreSQL) ──────────────────────────────────────────
# Get from: https://supabase.com/dashboard → Settings → Database → Connection string
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# Supabase client (for auth and storage)
SUPABASE_URL=https://[project-ref].supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ─── Redis (Upstash for production, local for development) ───────────────────
# Development: docker compose up -d (starts Redis on localhost:6379)
REDIS_URL=redis://localhost:6379

# Production (Upstash):
# UPSTASH_REDIS_URL=rediss://:[password]@[endpoint].upstash.io:6380

# ─── API Gateway ─────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-random-32-character-string-minimum
CORS_ORIGINS=http://localhost:3010,http://localhost:3011

# ─── ElevenLabs (Voice Agent) ────────────────────────────────────────────────
# Get from: https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=
ELEVENLABS_WEBHOOK_SECRET=

# ─── Twilio (Voice + SMS) ────────────────────────────────────────────────────
# Get from: https://console.twilio.com
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=+1...     # Default SMS sender number

# ─── Anthropic Claude (Chatbot, Social, Proposals) ───────────────────────────
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# ─── SendGrid (Email) ────────────────────────────────────────────────────────
# Get from: https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=SG....
SENDGRID_FROM_EMAIL=hello@embedo.ai
SENDGRID_FROM_NAME=Embedo

# ─── Calendly ────────────────────────────────────────────────────────────────
# Get from: https://developer.calendly.com
CALENDLY_CLIENT_ID=
CALENDLY_CLIENT_SECRET=
CALENDLY_WEBHOOK_SECRET=

# ─── Meta (Instagram + Facebook) ─────────────────────────────────────────────
# Get from: https://developers.facebook.com/apps
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
INSTAGRAM_WEBHOOK_SECRET=

# ─── Vercel (Website Generation) ─────────────────────────────────────────────
# Get from: https://vercel.com/account/tokens
VERCEL_API_TOKEN=
VERCEL_TEAM_ID=   # Optional: for team deployments

# ─── Replicate (Image Generation for Social Posts) ───────────────────────────
# Get from: https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=r8_...

# ─── Application URLs ────────────────────────────────────────────────────────
BASE_URL=http://localhost:3000          # API Gateway public URL
CHATBOT_API_URL=http://localhost:3003   # Chatbot service URL (for widget embed)
SURVEY_BASE_URL=http://localhost:3010/survey
PROPOSAL_BASE_URL=http://localhost:3010/proposal

# ─── Stripe (Billing) ────────────────────────────────────────────────────
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Create products/prices in Stripe Dashboard, then paste Price IDs here:
STRIPE_PRICE_SOLO=price_...     # $497/mo
STRIPE_PRICE_SMALL=price_...    # $797/mo
STRIPE_PRICE_MEDIUM=price_...   # $1,297/mo
STRIPE_PRICE_LARGE=price_...    # $2,497/mo

# ─── Internal Notifications ──────────────────────────────────────────────────
INTERNAL_NOTIFICATION_EMAIL=jason@embedo.ai
